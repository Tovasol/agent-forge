# TEMPLATE — documents the keys the deploy job needs. Do NOT put real values here
# and do NOT rename this to ci/secrets.enc.yaml. Create the real ENCRYPTED file with
# sops (it routes *.enc.yaml to the runner's age key via .sops.yaml automatically):
#
#     sops ci/secrets.enc.yaml        # opens $EDITOR; on save it writes ENCRYPTED
#       → add the two keys below with your real values, save, quit.
#
# Verify it's encrypted before committing:  grep -q ENC ci/secrets.enc.yaml && echo ok
#
# These become env vars inside the build container (decrypted host-side at run time,
# never written to disk in the box). wrangler reads them for non-interactive auth.
CLOUDFLARE_API_TOKEN: cf-token-with-Account.Cloudflare-Pages.Edit-permission
CLOUDFLARE_ACCOUNT_ID: your-cloudflare-account-id
