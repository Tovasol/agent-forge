# ─────────────────────────────────────────────────────────────────────────────
# Agent Forge — environment configuration
# Copy this file to `.env` and fill in what you need. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── AUTH ─────────────────────────────────────────────────────────────────────
# Two ways to authenticate the agent runtime. Pick ONE as your primary.
#
#   FORGE_AUTH=subscription   -> uses your Claude Code login (OAuth token).
#                                Start here. Good for personal, local use.
#   FORGE_AUTH=apikey         -> uses a pay-as-you-go Anthropic API key.
#                                The documented, policy-safe path for automated
#                                loops. Switch to this if you hit subscription
#                                limits or want clean billing/attribution.
#
# NOTE: If ANTHROPIC_API_KEY is set in your shell, the underlying Claude Code
# runtime will prefer it over the subscription session. To force subscription
# auth, leave ANTHROPIC_API_KEY empty AND set FORGE_AUTH=subscription.
FORGE_AUTH=subscription

# Only needed when FORGE_AUTH=apikey
ANTHROPIC_API_KEY=

# Optional: pin an OAuth token explicitly (otherwise the runtime uses your
# existing `claude` login session on this machine).
# CLAUDE_CODE_OAUTH_TOKEN=

# ── MODELS ───────────────────────────────────────────────────────────────────
# Lead/orchestrator + critic run on the strong model; research workers on the
# cheaper one. Override if model names change.
FORGE_MODEL_LEAD=claude-opus-4-8
FORGE_MODEL_WORKER=claude-sonnet-4-6
FORGE_MODEL_CHEAP=claude-haiku-4-5-20251001

# ── BUDGET / SAFETY RAILS ────────────────────────────────────────────────────
# Hard ceiling per run, in USD. The loop aborts if exceeded. Only enforced
# when FORGE_AUTH=apikey (subscription usage isn't dollar-metered locally).
FORGE_MAX_BUDGET_USD=25
# Max orchestrator turns before forced stop (anti-runaway).
FORGE_MAX_TURNS=120
# How many research workers may run in parallel.
FORGE_MAX_PARALLEL_WORKERS=4

# ── HUMAN GATES ──────────────────────────────────────────────────────────────
# autonomy=gated  -> full auto, pause only at spend/deploy gates (your choice)
# autonomy=phased -> pause after every phase
# autonomy=research-only -> stop after decisions
FORGE_AUTONOMY=gated

# ── BUSINESS BRIEF ───────────────────────────────────────────────────────────
# These seed the research. You can also edit config/brief.json directly.
FORGE_BUSINESS_NAME=
FORGE_NICHE=data pipeline service
FORGE_ICP=
FORGE_MONTHLY_BUDGET_USD=50

# ── WEB RESEARCH (optional MCP servers) ──────────────────────────────────────
# The agent uses Claude's native WebSearch/WebFetch by default (no key needed
# beyond your auth). Add any of these to unlock deeper scraping. Leave blank to
# skip — the agent adapts to whatever is available.
FIRECRAWL_API_KEY=
EXA_API_KEY=
TAVILY_API_KEY=

# ── DELIVERY STACK (your services) ───────────────────────────────────────────
# Cloudflare (site + Workers + D1). Used at the deploy gate.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Google Workspace (Sheets-based CRM + email). Path to a service-account JSON,
# or leave blank and the agent will emit setup instructions instead.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEETS_CRM_ID=
